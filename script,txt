-- Estado de arraste do botão JV
local draggingBtn = false
local dragStart = nil
local btnStartPos = nil

-- Conexão de entrada para menu (será ativada após créditos)
local menuInputConn

local function setupMenuInput()
    menuInputConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end

        local mousePos = UserInputService:GetMouseLocation()

        -- Clique no botão JV
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local btnBounds = {Position = btnJV.Position, Size = btnJV.Size}
            if mousePos.X >= btnBounds.Position.X and mousePos.X <= btnBounds.Position.X + btnBounds.Size.X and
               mousePos.Y >= btnBounds.Position.Y and mousePos.Y <= btnBounds.Position.Y + btnBounds.Size.Y then
                menuAberto = not menuAberto
                if menuAberto then
                    -- animação de abertura
                    menuAnimProgress = 0
                    spawn(function()
                        for i = 0, 1, 0.1 do
                            menuAnimProgress = i
                            renderMenu()
                            wait(0.02)
                        end
                        menuAnimProgress = 1
                        renderMenu()
                    end)
                else
                    -- animação de fechamento
                    menuAnimProgress = 1
                    spawn(function()
                        for i = 1, 0, -0.1 do
                            menuAnimProgress = i
                            renderMenu()
                            wait(0.02)
                        end
                        menuAnimProgress = 0
                        renderMenu()
                    end)
                end
                return
            end

            -- Verifica toggles
            if menuAberto then
                for _, toggle in ipairs(toggleDrawings) do
                    local a = toggle.clickArea
                    if mousePos.X >= a.Position.X and mousePos.X <= a.Position.X + a.Size.X and
                       mousePos.Y >= a.Position.Y and mousePos.Y <= a.Position.Y + a.Size.Y then
                        toggle.value = not toggle.value
                        toggle.check.Visible = toggle.value
                        toggle.bg.Color = toggle.value and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(80, 80, 80)
                        if toggle.callback then toggle.callback(toggle.value) end
                        return
                    end
                end

                -- Verifica sliders (início de arraste)
                for _, slider in ipairs(sliderDrawings) do
                    if slider.trackBg.Visible then
                        local trackPos = slider.trackBg.Position
                        local trackSize = slider.trackBg.Size
                        if mousePos.Y >= trackPos.Y - 5 and mousePos.Y <= trackPos.Y + trackSize.Y + 5 and
                           mousePos.X >= trackPos.X and mousePos.X <= trackPos.X + trackSize.X then
                            slider.dragging = true
                            -- atualiza valor imediatamente
                            local relX = math.clamp(mousePos.X - trackPos.X, 0, trackSize.X)
                            local t = relX / trackSize.X
                            slider.value = slider.min + t * (slider.max - slider.min)
                            slider.updateThumb()
                            if slider.callback then slider.callback(slider.value) end
                            return
                        end
                    end
                end
            end

            -- Início de arraste do botão
            local btnBounds = {Position = btnJV.Position, Size = btnJV.Size}
            if mousePos.X >= btnBounds.Position.X and mousePos.X <= btnBounds.Position.X + btnBounds.Size.X and
               mousePos.Y >= btnBounds.Position.Y and mousePos.Y <= btnBounds.Position.Y + btnBounds.Size.Y then
                draggingBtn = true
                dragStart = mousePos
                btnStartPos = btnJV.Position
            end
        end
    end)

    UserInputService.InputChanged:Connect(function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            local mousePos = UserInputService:GetMouseLocation()
            -- Arrastar botão
            if draggingBtn then
                local delta = mousePos - dragStart
                btnJV.Position = btnStartPos + delta
                btnJVText.Position = btnJV.Position + btnJV.Size/2
                menuBasePos = btnJV.Position + Vector2.new(0, btnJV.Size.Y + 5)
                renderMenu()
            end

            -- Arrastar sliders
            for _, slider in ipairs(sliderDrawings) do
                if slider.dragging then
                    local relX = math.clamp(mousePos.X - slider.trackBg.Position.X, 0, slider.trackBg.Size.X)
                    local t = relX / slider.trackBg.Size.X
                    slider.value = slider.min + t * (slider.max - slider.min)
                    slider.updateThumb()
                    if slider.callback then slider.callback(slider.value) end
                end
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingBtn = false
            for _, slider in ipairs(sliderDrawings) do
                slider.dragging = false
            end
        end
    end)
end

