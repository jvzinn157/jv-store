local function setCollapsed(collapsed, instant)
    if menuAnimating and not instant then return end
    menuAnimating = true

    local targetSize = collapsed and collapsedSize or expandedSize
    local targetPos = collapsed and collapsedPos or expandedPos

    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") or child:IsA("GuiObject") then
            child.Visible = not collapsed
        end
    end
    minimizeBtn.Visible = not collapsed
    closeBtn.Visible = not collapsed
    creditsSubLabel.Visible = not collapsed
    titleLabel.Text = collapsed and "JV" or "JV Store"
    scrollFrame.Visible = not collapsed

    if instant then
        mainFrame.Size = targetSize
        mainFrame.Position = targetPos
        menuCollapsed = collapsed
        menuAnimating = false
    else
        TweenService:Create(mainFrame, TweenInfo.new(0.15), {Size = targetSize, Position = targetPos}):Play()
        task.wait(0.15)
        menuCollapsed = collapsed
        menuAnimating = false
    end
end

