-- Função para criar um toggle (checkbox + texto)
local function createToggle(text, defaultValue, callback)
    local toggle = {}
    local yOffset = #toggleDrawings * 25 + 5

    toggle.bg = Drawing.new("Square")
    toggle.bg.Size = Vector2.new(16, 16)
    toggle.bg.Position = panelBg.Position + Vector2.new(10, yOffset)
    toggle.bg.Color = defaultValue and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(80, 80, 80)
    toggle.bg.Filled = true
    toggle.bg.Visible = false

    toggle.check = Drawing.new("Square")
    toggle.check.Size = Vector2.new(12, 12)
    toggle.check.Position = toggle.bg.Position + Vector2.new(2, 2)
    toggle.check.Color = Color3.fromRGB(255, 255, 255)
    toggle.check.Filled = true
    toggle.check.Visible = defaultValue

    toggle.label = Drawing.new("Text")
    toggle.label.Text = text
    toggle.label.Size = 14
    toggle.label.Position = toggle.bg.Position + Vector2.new(22, -1)
    toggle.label.Color = Color3.fromRGB(255, 255, 255)
    toggle.label.Font = 2
    toggle.label.Visible = false

    toggle.value = defaultValue
    toggle.callback = callback

    toggle.clickArea = {  -- hitbox para clique
        Position = toggle.bg.Position,
        Size = Vector2.new(100, 20)  -- largura suficiente para texto
    }

    table.insert(toggleDrawings, toggle)
    return toggle
end

-- Função para criar um slider (barra + thumb)
local function createSlider(text, min, max, initial, callback)
    local slider = {}
    local yOffset = #sliderDrawings * 30 + 5 + #toggleDrawings * 25 + 5

    slider.label = Drawing.new("Text")
    slider.label.Text = text .. ": " .. initial
    slider.label.Size = 14
    slider.label.Position = panelBg.Position + Vector2.new(10, yOffset)
    slider.label.Color = Color3.fromRGB(255, 255, 255)
    slider.label.Font = 2
    slider.label.Visible = false

    slider.trackBg = Drawing.new("Square")
    slider.trackBg.Size = Vector2.new(150, 6)
    slider.trackBg.Position = slider.label.Position + Vector2.new(0, 18)
    slider.trackBg.Color = Color3.fromRGB(80, 80, 80)
    slider.trackBg.Filled = true
    slider.trackBg.Visible = false

    slider.trackFill = Drawing.new("Square")
    slider.trackFill.Size = Vector2.new(0, 6)
    slider.trackFill.Position = slider.trackBg.Position
    slider.trackFill.Color = Color3.fromRGB(0, 170, 0)
    slider.trackFill.Filled = true
    slider.trackFill.Visible = false

    slider.thumb = Drawing.new("Square")
    slider.thumb.Size = Vector2.new(12, 12)
    slider.thumb.Position = slider.trackBg.Position + Vector2.new(0, -3)
    slider.thumb.Color = Color3.fromRGB(255, 255, 255)
    slider.thumb.Filled = true
    slider.thumb.Visible = false

    slider.value = initial
    slider.min = min
    slider.max = max
    slider.callback = callback
    slider.dragging = false

    -- atualiza posição do thumb
    local function updateThumb()
        local t = (slider.value - min) / (max - min)
        local x = slider.trackBg.Position.X + t * slider.trackBg.Size.X
        slider.thumb.Position = Vector2.new(x - slider.thumb.Size.X/2, slider.trackBg.Position.Y - 3)
        slider.trackFill.Size = Vector2.new(t * slider.trackBg.Size.X, 6)
        slider.label.Text = text .. ": " .. math.floor(slider.value * 10) / 10
    end
    updateThumb()

    slider.updateThumb = updateThumb
    table.insert(sliderDrawings, slider)
    return slider
end

-- Função para desenhar todos os elementos do menu
local function renderMenu()
    local alpha = menuAnimProgress
    panelBg.Size = Vector2.new(
        menuTargetSize.X * alpha,
        menuTargetSize.Y * alpha
    )
    panelBg.Position = menuBasePos

    -- Atualiza posições dos toggles
    for i, toggle in ipairs(toggleDrawings) do
        local yOff = (i-1) * 25 + 5
        toggle.bg.Position = panelBg.Position + Vector2.new(10, yOff)
        toggle.check.Position = toggle.bg.Position + Vector2.new(2, 2)
        toggle.label.Position = toggle.bg.Position + Vector2.new(22, -1)
        toggle.clickArea.Position = toggle.bg.Position
        toggle.bg.Visible = alpha > 0 and menuAberto
        toggle.check.Visible = toggle.value and alpha > 0 and menuAberto
        toggle.label.Visible = alpha > 0 and menuAberto
    end

    -- Atualiza posições dos sliders
    local sliderBaseY = #toggleDrawings * 25 + 10
    for i, slider in ipairs(sliderDrawings) do
        local yOff = sliderBaseY + (i-1) * 35
        slider.label.Position = panelBg.Position + Vector2.new(10, yOff)
        slider.trackBg.Position = slider.label.Position + Vector2.new(0, 18)
        slider.trackFill.Position = slider.trackBg.Position
        local t = (slider.value - slider.min) / (slider.max - slider.min)
        local x = slider.trackBg.Position.X + t * slider.trackBg.Size.X
        slider.thumb.Position = Vector2.new(x - slider.thumb.Size.X/2, slider.trackBg.Position.Y - 3)
        slider.trackFill.Size = Vector2.new(t * slider.trackBg.Size.X, 6)
        slider.label.Visible = alpha > 0 and menuAberto
        slider.trackBg.Visible = alpha > 0 and menuAberto
        slider.trackFill.Visible = alpha > 0 and menuAberto
        slider.thumb.Visible = alpha > 0 and menuAberto
        slider.label.Text = slider.label.Text:gsub("%:.*", ": " .. math.floor(slider.value * 10) / 10)
    end
end

