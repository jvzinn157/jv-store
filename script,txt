-- Sistema de arraste (apenas cabeçalho/bordas)
local draggingMenu = false
local dragStartPos = nil
local dragStartFrame = nil
local isDrag = false
local minDragDistance = 3

local function isMouseOverScrollFrame(mousePos)
    if scrollFrame.Visible and scrollFrame.AbsolutePosition and scrollFrame.AbsoluteSize then
        local pos = scrollFrame.AbsolutePosition
        local size = scrollFrame.AbsoluteSize
        return mousePos.X >= pos.X and mousePos.X <= pos.X + size.X and
               mousePos.Y >= pos.Y and mousePos.Y <= pos.Y + size.Y
    end
    return false
end

local function startDrag(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        local mousePos = input.Position
        if isMouseOverScrollFrame(mousePos) then
            draggingMenu = false
            return
        end
        for _, area in ipairs(interactiveAreas) do
            if area.Visible and area.AbsolutePosition and area.AbsoluteSize then
                local pos = area.AbsolutePosition
                local size = area.AbsoluteSize
                if mousePos.X >= pos.X and mousePos.X <= pos.X + size.X and
                   mousePos.Y >= pos.Y and mousePos.Y <= pos.Y + size.Y then
                    draggingMenu = false
                    return
                end
            end
        end
        draggingMenu = true
        isDrag = false
        dragStartPos = mousePos
        dragStartFrame = mainFrame.Position
    end
end

mainFrame.InputBegan:Connect(startDrag)

UserInputService.InputChanged:Connect(function(input)
    if draggingMenu and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartPos
        if delta.Magnitude > minDragDistance then
            isDrag = true
        end
        if isDrag then
            local newPos = UDim2.new(dragStartFrame.X.Scale, dragStartFrame.X.Offset + delta.X,
                                    dragStartFrame.Y.Scale, dragStartFrame.Y.Offset + delta.Y)
            mainFrame.Position = newPos
            if menuCollapsed then
                collapsedPos = newPos
            else
                expandedPos = newPos
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if draggingMenu and not isDrag then
            if menuCollapsed then
                setCollapsed(false, false)
            end
        end
        draggingMenu = false
        isDrag = false
    end
end)

