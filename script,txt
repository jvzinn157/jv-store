-- ===== SCRIPT PRINCIPAL =====
local scriptIniciado = false
local mainLoopConn
local FOVring = nil
local espObjects = {}

function iniciarScript()
    if scriptIniciado then return end
    scriptIniciado = true

    local FOVring = Drawing.new("Circle")
    FOVring.Visible = true
    FOVring.Thickness = fovThickness
    FOVring.Color = Color3.fromRGB(128, 0, 128)
    FOVring.Filled = false
    FOVring.Radius = fov
    FOVring.Position = Cam.ViewportSize / 2

    local function updateDrawings()
        FOVring.Position = Cam.ViewportSize / 2
        FOVring.Radius = fov
        FOVring.Thickness = fovThickness
    end

    local function isPlayerVisible(player)
        local char = player.Character
        if not char then return false end
        local head = char:FindFirstChild("Head")
        if not head then return false end

        local cameraPos = Cam.CFrame.Position
        local targetPos = head.Position

        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Blacklist
        params.FilterDescendantsInstances = { localChar, char }

        local result = Workspace:Raycast(cameraPos, (targetPos - cameraPos), params)
        return result == nil
    end

    local function lookAt(target)
        local lookVector = (target - Cam.CFrame.Position).unit
        local newCFrame = CFrame.new(Cam.CFrame.Position, Cam.CFrame.Position + lookVector)
        Cam.CFrame = newCFrame
    end

    local function getClosestPlayerInFOV(trg_part)
        local nearest = nil
        local last = math.huge
        local mousePos = Cam.ViewportSize / 2

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer then
                local char = player.Character
                if char then
                    local part = char:FindFirstChild(trg_part)
                    if part then
                        local ePos, isOnScreen = Cam:WorldToViewportPoint(part.Position)
                        local distance = (Vector2.new(ePos.x, ePos.y) - mousePos).Magnitude
                        if isOnScreen and distance < fov and distance < last and isPlayerVisible(player) then
                            last = distance
                            nearest = player
                        end
                    end
                end
            end
        end
        return nearest
    end

    local function createESP(player)
        if espObjects[player] then return end
        local data = {
            box = Drawing.new("Square"),
            tracer = Drawing.new("Line"),
            distanceText = Drawing.new("Text")
        }
        data.box.Visible = false
        data.box.Thickness = 1.5
        data.box.Color = Color3.fromRGB(0, 255, 0)
        data.box.Transparency = 1 - boxOpacity
        data.box.Filled = false

        data.tracer.Visible = false
        data.tracer.Thickness = 1.5
        data.tracer.Color = Color3.fromRGB(255, 255, 255)
        data.tracer.Transparency = 1 - tracerOpacity

        data.distanceText.Visible = false
        data.distanceText.Size = 14
        data.distanceText.Center = true
        data.distanceText.Color = Color3.fromRGB(255, 255, 255)
        data.distanceText.Transparency = 0
        data.distanceText.Font = 0

        espObjects[player] = data
    end

    local function removeESP(player)
        local data = espObjects[player]
        if data then
            data.box:Remove()
            data.tracer:Remove()
            data.distanceText:Remove()
            espObjects[player] = nil
        end
    end

    local function updateESP()
        if not espAtivo then
            for _, data in pairs(espObjects) do
                data.box.Visible = false
                data.tracer.Visible = false
                data.distanceText.Visible = false
            end
            return
        end

        local viewport = Cam.ViewportSize
        local bottomCenter = Vector2.new(viewport.X / 2, viewport.Y)

        for player, data in pairs(espObjects) do
            local char = player.Character
            if not char or not player.Parent then
                removeESP(player)
                continue
            end

            local head = char:FindFirstChild("Head")
            local torso = char:FindFirstChild("Torso") 
                       or char:FindFirstChild("UpperTorso") 
                       or char:FindFirstChild("LowerTorso") 
                       or char:FindFirstChild("HumanoidRootPart")
            
            if head and torso then
                local headPos, headVis = Cam:WorldToViewportPoint(head.Position)
                local torsoPos = Cam:WorldToViewportPoint(torso.Position)

                if headVis then
                    local distance = math.floor((Cam.CFrame.Position - head.Position).Magnitude)
                    local height = math.abs(headPos.Y - torsoPos.Y) * 3.5
                    local width = height * 0.5
                    local centerX = headPos.X
                    local centerY = (headPos.Y + torsoPos.Y) / 2

                    data.box.Visible = boxAtivo
                    if boxAtivo then
                        data.box.Size = Vector2.new(width, height)
                        data.box.Position = Vector2.new(centerX - width/2, centerY - height/2)
                        data.box.Transparency = 1 - boxOpacity
                    end

                    data.tracer.Visible = tracerAtivo
                    if tracerAtivo then
                        data.tracer.From = bottomCenter
                        data.tracer.To = Vector2.new(headPos.X, headPos.Y)
                        data.tracer.Transparency = 1 - tracerOpacity
                    end

                    data.distanceText.Visible = distanciaAtivo
                    if distanciaAtivo then
                        data.distanceText.Text = tostring(distance) .. "m"
                        data.distanceText.Position = Vector2.new(headPos.X, headPos.Y + height/2 + 20)
                    end
                else
                    data.box.Visible = false
                    data.tracer.Visible = false
                    data.distanceText.Visible = false
                end
            else
                data.box.Visible = false
                data.tracer.Visible = false
                data.distanceText.Visible = false
            end
        end
    end

    local function setupPlayer(player)
        if player == localPlayer then return end
        player.CharacterAdded:Connect(function()
            removeESP(player)
            createESP(player)
        end)
        if player.Character then createESP(player) end
    end

    for _, player in ipairs(Players:GetPlayers()) do setupPlayer(player) end
    Players.PlayerAdded:Connect(setupPlayer)
    Players.PlayerRemoving:Connect(removeESP)
    localPlayer.CharacterAdded:Connect(function(char) localChar = char end)

    menuReady = true
    aimbotReady = true
    espReady = true
    boxReady = true
    tracerReady = true
    distanciaReady = true
    fovReady = true

    -- Notificações principais (sem duplicar a do Anti‑Kick)
    task.spawn(function()
        showNotification("🟨 Carregando Script...", Color3.fromRGB(255, 255, 0), 2)
        task.wait(2.5)

        -- Aguarda o Anti‑Kick estar pronto (já estará, pois foi inicializado antes)
        while not antiKickReady do
            task.wait(0.5)
        end
        -- Não exibe notificação extra; a do loader já apareceu
        task.wait(1)

        showNotification("🟩 Menu JV Store carregado.", Color3.fromRGB(0, 255, 0), 2)
        task.wait(2.5)

        showNotification("🟨 Verificando recursos...", Color3.fromRGB(255, 255, 0), 2)
        task.wait(2.5)

        local allReady = (FOVring and espObjects and mainLoopConn)
        if allReady then
            showNotification("🟩 Verificação concluída.", Color3.fromRGB(0, 255, 0), 2)
            task.wait(2.5)
            showNotification("🟩 Script iniciado com sucesso.", Color3.fromRGB(0, 255, 0), 2)
        else
            showNotification("🟥 Erro na verificação de recursos.", Color3.fromRGB(255, 0, 0), 3)
        end
    end)

    function fullCleanup()
        if mainLoopConn then mainLoopConn:Disconnect(); mainLoopConn = nil end
        if FOVring then FOVring:Remove() end
        for player, data in pairs(espObjects) do removeESP(player) end
        espObjects = {}
        menuGui:Destroy()
        notificationGui:Destroy()
        pcall(function() loadingText:Remove(); subText:Remove(); creditosText:Remove(); creditosSub:Remove(); creditBg:Remove() end)
    end

    UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Delete then
            fullCleanup()
        end
    end)

    mainLoopConn = RunService.RenderStepped:Connect(function()
        updateDrawings()

        local baseTransparency = 1 - fovOpacity
        if aimbotAtivo then
            local closest = getClosestPlayerInFOV("Head")
            if closest and closest.Character and closest.Character:FindFirstChild("Head") then
                if isPlayerVisible(closest) then
                    lookAt(closest.Character.Head.Position)
                end
                local ePos, isVis = Cam:WorldToViewportPoint(closest.Character.Head.Position)
                if isVis then
                    local dist = (Vector2.new(ePos.x, ePos.y) - Cam.ViewportSize / 2).Magnitude
                    FOVring.Transparency = math.clamp(baseTransparency + (1 - (dist / fov)) * maxTransparency, 0, 1)
                else
                    FOVring.Transparency = baseTransparency
                end
            else
                FOVring.Transparency = baseTransparency
            end
        else
            FOVring.Transparency = baseTransparency
        end

        updateESP()
        updateInfoStatus()
        monitorAndRetry()
    end)
end

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Delete and not scriptIniciado then
        creditosAtivos = false
        loadingText:Remove(); subText:Remove(); creditosText:Remove(); creditosSub:Remove()
        creditBg:Remove()
        if creditosConn then creditosConn:Disconnect(); creditosConn = nil end
        iniciarScript()
    end
end)
