blurEffect.Enabled = false

creditosConn = RunService.RenderStepped:Connect(function()
    if not creditosAtivos then return end
    creditosTempo = creditosTempo + 0.016

    -- Fase 1: loading
    if creditosFase == 1 then
        local alpha = math.min(creditosTempo / 1.0, 1)
        loadingText.Transparency = 1 - alpha
        subText.Transparency = 1 - alpha

        pontos = pontos + 1
        if pontos > 3 then pontos = 0 end
        local pontoStr = ""
        for i = 1, pontos do pontoStr = pontoStr .. "." end
        subText.Text = pontoStr

        if creditosTempo > 2.0 then
            creditosFase = 2
            creditosTempo = 0
            loadingText.Visible = false
            subText.Visible = false
        end

    -- Fase 2: créditos com blur
    elseif creditosFase == 2 then
        local alpha = math.min(creditosTempo / 0.8, 1)
        creditosText.Transparency = 1 - alpha
        creditosSub.Transparency = 1 - alpha

        -- Ativa blur e fade in
        if not blurEffect.Enabled then
            blurEffect.Enabled = true
            blurEffect.Size = 0
            TweenService:Create(blurEffect, TweenInfo.new(0.5), {Size = 24}):Play()
        end

        if creditosTempo > 4.0 then
            creditosFase = 3
            creditosTempo = 0
        end

    -- Fase 3: fade out créditos e blur
    elseif creditosFase == 3 then
        local alpha = math.min(creditosTempo / 0.8, 1)
        creditosText.Transparency = alpha
        creditosSub.Transparency = alpha

        -- Desfoque desaparece suavemente
        if blurEffect.Size > 0 then
            TweenService:Create(blurEffect, TweenInfo.new(0.5), {Size = 0}):Play()
        end

        if creditosTempo > 1.0 then
            creditosAtivos = false
            creditosText.Visible = false
            creditosSub.Visible = false
            loadingText.Visible = false
            subText.Visible = false
            blurEffect.Enabled = false
            blurGui:Destroy()  -- limpa GUI do blur
            if creditosConn then
                creditosConn:Disconnect()
                creditosConn = nil
            end
            iniciarScript()
        end
    end
end)

